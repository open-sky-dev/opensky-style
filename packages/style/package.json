{
  "name": "@opensky/style",
  "author": "notnotjake",
  "description": "Utilities for styling in svelte",
  "version": "0.2.0",
  "repository": {
    "directory": "packages/style",
    "type": "git",
    "url": "https://github.com/open-sky-dev/opensky-style.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./index.ts --outfile ./dist/index.js --format esm --packages external && tsc --project tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.0"
  }
}
